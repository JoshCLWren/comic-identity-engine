#!/usr/bin/env bash
# direnv configuration for Comic Identity Engine

source "$PWD/scripts/ensure-local-venv.sh"
cie_ensure_local_venv "$PWD"

# Optional local-only secrets for third-party integrations.
if [[ -f "$PWD/.env.hip.local" ]]; then
  source "$PWD/.env.hip.local"
fi

# Database Configuration
export DATABASE_URL="postgresql+asyncpg://comic_user:comic_pass@localhost:5434/comic_identity"
export TEST_DATABASE_URL="postgresql+asyncpg://comic_user:comic_pass@localhost:5434/comic_identity_test"

# Redis Configuration (DB 0 for arq job queue, DB 1 for app cache)
export REDIS_URL="redis://localhost:6381/0"
export REDIS_CACHE_DB="1"

# arq Job Queue Configuration
export ARQ_QUEUE_URL="redis://localhost:6381/0"
export ARQ_QUEUE_NAME="cie:local:queue"

# API Configuration
export API_HOST="0.0.0.0"
export API_PORT="8000"

# Development Settings
export PYTHONDONTWRITEBYTECODE="1"
export PYTHONUNBUFFERED="1"

# Logging Configuration
export LOG_LEVEL="INFO"
export LOG_FORMAT="console"  # json or console

# API Settings
export API_RELOAD="True"  # Enable auto-reload in development

# Worker Settings
export WORKER_CONCURRENCY="10"
export WORKER_TIMEOUT="3000"  # 50 minutes max per job (10x increase)

# Platform Search Settings
export ADAPTER_PLATFORM_SEARCH_TIMEOUT="60"  # 60s timeout per platform (prevents GCD rate limiting from blocking bulk extraction)

echo "✅ Comic Identity Engine environment loaded"
echo "   Database: postgresql://comic_user:***@localhost:5434/comic_identity"
echo "   Redis: $REDIS_URL"
echo "   Log Level: $LOG_LEVEL ($LOG_FORMAT)"
echo ""
echo "💡 To start services: docker compose up -d postgres-app redis"
echo "💡 To run migrations: alembic upgrade head"
echo "💡 To start API: cie-api --reload"
echo "💡 To start worker: cie-worker"
echo "💡 To test CLI: cie-find --help"
