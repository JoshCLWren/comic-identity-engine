# Database (uses asyncpg driver for SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://comic_user:comic_pass@localhost:5434/comic_identity
TEST_DATABASE_URL=postgresql+asyncpg://comic_user:comic_pass@localhost:5434/comic_identity_test

# Redis (DB 1 for app cache, DB 0 for arq queue)
REDIS_URL=redis://localhost:6381/1

# arq Job Queue
ARQ_QUEUE_URL=redis://localhost:6381/0
ARQ_QUEUE_NAME=cie:local:queue
ARQ_QUEUE_SIZE=10000  # Maximum tasks in queue (0 = unlimited, supports 100k+ tasks)
ARQ_MAX_JOBS=100  # Process 100 tasks per poll cycle (high throughput)
ARQ_POLL_INTERVAL=0.1  # Poll every 100ms (0.1 seconds = high throughput)
ARQ_JOB_TIMEOUT=300  # 5 minutes max per job
ARQ_KEEP_RESULT=3600  # Keep results for 1 hour

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console  # json or console

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True  # Enable auto-reload in development

# Workers
WORKER_CONCURRENCY=10
WORKER_TIMEOUT=300  # 5 minutes max per job
