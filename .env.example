# Database
DATABASE_URL=postgresql://comic_user:comic_pass@localhost:5432/comic_identity

# Redis
REDIS_URL=redis://localhost:6379/1  # DB 1 for app cache (DB 0 for arq queue)

# arq
ARQ_REDIS_DB=0  # DB 0 for arq queue

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or console

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True  # Enable auto-reload in development

# Workers
WORKER_CONCURRENCY=10
WORKER_TIMEOUT=300  # 5 minutes max per job
